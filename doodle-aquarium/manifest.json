{
  "manifest_version": 3,
  "name": "Doodle Aquarium",
  "version": "1.0",
  "description": "Create a doodle aquarium over the browser screen. Draw fish and let them swim!",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "js/common/image-utils.js",
        "js/content/settings.js",
        "js/content/viewport-utils.js",
        "js/content/simulation.js",
        "js/content/aquarium-engine.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
